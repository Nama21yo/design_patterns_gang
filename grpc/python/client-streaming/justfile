default:
    @just --list

# Create or refresh the shared Python virtual environment.
setup:
    uv venv ../.venv
    uv pip install --python ../.venv/bin/python grpcio grpcio-tools protobuf

# Compile the client-streaming proto file into Python code.
compile:
    $(realpath -s ../.venv/bin/python) -m grpc_tools.protoc -I. --python_out=. --grpc_python_out=. sensor.proto
    @echo "Client-streaming protobuf compiled successfully."

# Run the client-streaming RPC server.
server: compile
    $(realpath -s ../.venv/bin/python) server.py

# Run the client-streaming RPC client.
client: compile
    $(realpath -s ../.venv/bin/python) client.py

# Run the client with custom readings:
# just client-readings "20,21,24,25"
client-readings readings: compile
    $(realpath -s ../.venv/bin/python) client.py "{{readings}}"

# Remove generated protobuf files.
clean:
    rm -f *_pb2.py *_pb2_grpc.py
    @echo "Cleaned generated files."
